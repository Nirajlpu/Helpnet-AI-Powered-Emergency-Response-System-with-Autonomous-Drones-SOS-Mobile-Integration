# Database
DB_PASSWORD=your_secure_password_here

# Django
DJANGO_SECRET_KEY=your-secret-key-here-min-50-chars-long-for-production
DEBUG=False
ALLOWED_HOSTS=api.helpnet.com,localhost,127.0.0.1

# Security
ENCRYPTION_KEY_PATH=/secure/keys/
JWT_SECRET=your-jwt-secret

# External Services
MAPBOX_TOKEN=pk.your_mapbox_token_here
OPENAI_API_KEY=sk-your_openai_key
HUGGINGFACE_TOKEN=hf_your_huggingface_token

# Mobile
FIREBASE_SERVER_KEY=your_firebase_key

# Blockchain (for evidence)
BLOCKCHAIN_NODE_URL=https://ethereum-node.example.com
SMART_CONTRACT_ADDRESS=0x...

# AWS S3 (for media storage)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=helpnet-evidence